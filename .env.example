# Copier vers .env et ajuster.

# --- LLM (chat) ---
# groq = rapide, quota gratuit (clé : https://console.groq.com/keys )
# gemini = Google AI Studio
# ollama = local
LLM_PROVIDER=groq
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

CHAT_TEMPERATURE=0.15
# Messages récents pour le chat libre (évite que l’historique noie la dernière question)
# CHAT_HISTORY_MAX_MESSAGES=8
# Contexte injecté pour SQL / réponse PDF (suites « pareil », « et ensuite »)
# CONVERSATION_CONTEXT_MAX_MESSAGES=16
# CONVERSATION_CONTEXT_MAX_CHARS=450
# Petit appel LLM avant SQL/RAG : CHAT (fil seul) vs LOOKUP (fichiers). Désactiver : false
# DATASET_TOOL_ROUTER_ENABLED=true
# Taille max du dernier message assistant vu par le routeur (début+fin si très long)
# DATASET_ROUTER_SNIPPET_CHARS=2600
# Limite de sortie du routeur (économise des tokens)
# DATASET_ROUTER_MAX_OUTPUT_TOKENS=16
# Étapes max par tour pour le mode auto/agent (boucle outils)
# DATASET_AGENT_MAX_STEPS=6
LLM_REQUEST_TIMEOUT=90
LLM_MAX_RETRIES=2

# --- Embeddings (index PDF / RAG) ---
EMBEDDINGS_PROVIDER=sentence_transformers
EMBEDDINGS_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Stockage des datasets
# DATA_DIR=./data

# Limites (API / interface)
# MAX_UPLOAD_MB=25
# MAX_TABLE_ROWS=20000
# MAX_WORKSPACE_FILES=3
# RATE_LIMIT_ENABLED=true
# RATE_LIMIT_PER_MINUTE=180

# --- Tabulaire (CSV/Excel) : aide SQL (profiling + indices recherche) ---
# Désactiver si besoin (perf) :
# TABULAR_PROFILE_ENABLED=true
# TABULAR_PROFILE_MODE=light   # light | full
# TABULAR_PROFILE_TTL_SECONDS=120
# TABULAR_SEARCH_SIGNALS_ENABLED=true
# TABULAR_SEARCH_SIGNALS_TTL_SECONDS=120

# Aperçu (GET /datasets/.../preview)
# PREVIEW_MAX_PDF_PAGES=8
# PREVIEW_MAX_CHARS_PDF_PAGE=5000
# PREVIEW_MAX_TABULAR_ROWS=150
